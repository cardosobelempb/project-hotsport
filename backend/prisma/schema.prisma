generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("admins")
}

model MercadoPagoConfig {
  id            Int      @id @default(autoincrement())
  publicKey     String?  @db.VarChar(255) @map("public_key")
  accessToken   String?  @db.Text @map("access_token")
  clientId      String?  @db.VarChar(255) @map("client_id")
  clientSecret  String?  @db.Text @map("client_secret")
  webhookSecret String?  @db.VarChar(255) @map("webhook_secret")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("config_mercadopago")
}

model EfiConfig {
  id              Int         @id @default(autoincrement())
  clientId        String      @db.VarChar(255) @map("client_id")
  clientSecret    String      @db.VarChar(255) @map("client_secret")
  pixKey          String      @db.VarChar(255) @map("chave_pix")
  environment     Environment @default(SANDBOX) @map("ambiente")
  certificateName String?     @db.VarChar(255) @map("certificado_nome")
  createdAt       DateTime    @default(now()) @map("criado_em")

  @@map("efi_config")
}

enum Environment {
  SANDBOX
  PRODUCTION

  @@map("Ambiente")
}

model LgpdLogin {
  id          Int      @id @default(autoincrement())
  cpf         String   @db.VarChar(14)
  accepted    Boolean  @default(false) @map("aceite")
  macAddress  String?  @db.VarChar(50) @map("mac")
  ipAddress   String?  @db.VarChar(50) @map("ip")
  createdAt   DateTime @default(now()) @map("criado_em")
  name        String?  @db.VarChar(100) @map("nome")
  phoneNumber String?  @db.VarChar(20) @map("telefone")

  @@map("lgpd_logins")
}

model MikrotikRouter {
  id          Int     @id @default(autoincrement())
  name        String  @db.VarChar(100) @map("nome")
  ipAddress   String  @db.VarChar(45) @map("ip")
  username    String  @db.VarChar(100) @map("usuario")
  password    String  @db.VarChar(255) @map("senha")
  port        Int     @default(8728) @map("porta")
  status      String  @default("Offline") @db.VarChar(20)
  activeUsers Int     @default(0) @map("usuarios_ativos")
  createdAt   DateTime @default(now()) @map("criado_em")
  hotspotUrl  String? @db.VarChar(255) @map("end_hotspot")

  plans Plan[]

  @@map("mikrotiks")
}

model Payment {
  id             Int      @id @default(autoincrement())
  planId         Int      @map("plano_id")
  email          String?  @db.VarChar(255)
  planName       String?  @db.VarChar(255) @map("nome_plano")
  amountCents    Int      @map("valor")
  status         String?  @db.VarChar(50)
  mercadoPagoId  BigInt?  @map("mp_pagamento_id")
  createdAt      DateTime @default(now()) @map("criado_em")
  expiresAt      DateTime? @map("expira_em")
  updatedAt      DateTime @default(now()) @updatedAt @map("atualizado_em")
  macAddress     String?  @db.VarChar(20) @map("mac")
  cpf            String?  @db.VarChar(20)
  ipAddress      String?  @db.VarChar(20) @map("IP")

  @@map("pagamentos")
}

model Plan {
  id            Int      @id @default(autoincrement())
  name          String   @db.VarChar(100) @map("nome")
  description   String?  @db.Text @map("descricao")
  price         Decimal  @db.Decimal(10, 2) @map("valor")
  durationMins  Int      @map("duracao_minutos")
  downloadSpeed String   @db.VarChar(20) @map("velocidade_down")
  uploadSpeed   String   @db.VarChar(20) @map("velocidade_up")
  mikrotikId    Int      @map("mikrotik_id")
  isActive      Boolean  @default(true) @map("ativo")
  addressPool   String   @default("default-dhcp") @db.VarChar(50) @map("address_pool")
  sharedUsers   Int      @default(10) @map("shared_users")

  mikrotik MikrotikRouter @relation(fields: [mikrotikId], references: [id], onDelete: Cascade)

  @@map("planos")
}

// ── User (OTP auth via WhatsApp) ─────────────────────────────────────────────

model User {
  id          String    @id @default(uuid()) @db.Uuid
  cpf         String    @unique @db.VarChar(14)
  name        String?   @db.VarChar(100)
  phoneNumber String?   @db.VarChar(20) @map("phone")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  otps UserOtp[]

  @@index([cpf])
  @@index([phoneNumber])
  @@map("users")
}

model UserOtp {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid @map("user_id")
  otpHash   String   @db.VarChar(255) @map("hash")
  expiresAt DateTime @map("expires_at")
  attempts  Int      @default(0)
  isUsed    Boolean  @default(false) @map("used")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([userId, createdAt])
  @@map("user_otps")
}

model RadiusUser {
  id        Int      @id @default(autoincrement())
  username  String   @db.VarChar(255)
  planId    Int?     @map("plano_id")
  nasId     Int?     @map("nas_id")
  createdAt DateTime @default(now()) @map("criado_em")

  @@map("radius_users")
}

model Radcheck {
  id        Int    @id @default(autoincrement())
  username  String @db.VarChar(64)
  attribute String @default("Cleartext-Password") @db.VarChar(64)
  op        String @default(":=") @db.Char(2)
  value     String @db.VarChar(253)

  @@map("radcheck")
}

model Radreply {
  id        Int    @id @default(autoincrement())
  username  String @db.VarChar(64)
  attribute String @db.VarChar(64)
  op        String @default(":=") @db.Char(2)
  value     String @db.VarChar(253)

  @@map("radreply")
}

model Radusergroup {
  username  String @db.VarChar(64)
  groupname String @db.VarChar(64)
  priority  Int    @default(1)

  @@id([username, groupname])
  @@map("radusergroup")
}

model OtpRequest {
  id          Int      @id @default(autoincrement())
  cpf         String   @db.VarChar(14)
  phoneNumber String   @db.VarChar(20) @map("telefone")
  otpHash     String   @db.VarChar(255) @map("otp_hash")
  expiresAt   DateTime @map("expires_at")
  attempts    Int      @default(0)
  maxAttempts Int      @default(5) @map("max_attempts")
  isUsed      Boolean  @default(false) @map("used")
  createdAt   DateTime @default(now()) @map("criado_em")

  @@map("otp_requests")
}

model OtpAuditLog {
  id          Int      @id @default(autoincrement())
  event       String   @db.VarChar(50)
  cpf         String   @db.VarChar(14)
  phoneNumber String?  @db.VarChar(20) @map("telefone")
  ipAddress   String?  @db.VarChar(45) @map("ip")
  detail      String?  @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("criado_em")

  @@index([cpf])
  @@index([event])
  @@index([createdAt])
  @@map("otp_audit_logs")
}
