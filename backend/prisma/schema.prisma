generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("admins")
}

model ConfigMercadoPago {
  id            Int      @id @default(autoincrement())
  publicKey     String?  @db.VarChar(255) @map("public_key")
  accessToken   String?  @db.Text @map("access_token")
  clientId      String?  @db.VarChar(255) @map("client_id")
  clientSecret  String?  @db.Text @map("client_secret")
  webhookSecret String?  @db.VarChar(255) @map("webhook_secret")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("config_mercadopago")
}

model EfiConfig {
  id              Int         @id @default(autoincrement())
  clientId        String      @db.VarChar(255) @map("client_id")
  clientSecret    String      @db.VarChar(255) @map("client_secret")
  pixKey          String      @db.VarChar(255) @map("pix_key")
  environment     Environment @default(SANDBOX)
  certificateName String?     @db.VarChar(255) @map("certificate_name")
  createdAt       DateTime    @default(now()) @map("created_at")

  @@map("efi_config")
}

enum Environment {
  SANDBOX
  PRODUCTION
}

model LgpdLogin {
  id        Int      @id @default(autoincrement())
  cpf       String   @db.VarChar(14)
  consent   Boolean  @default(false)
  mac       String?  @db.VarChar(50)
  ip        String?  @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")
  name      String?  @db.VarChar(100)
  phone     String?  @db.VarChar(20)

  @@map("lgpd_logins")
}

model Mikrotik {
  id             Int      @id @default(autoincrement())
  name           String   @db.VarChar(100)
  ip             String   @db.VarChar(45)
  username       String   @db.VarChar(100)
  password       String   @db.VarChar(255)
  port           Int      @default(8728)
  status         String   @default("Offline") @db.VarChar(20)
  activeUsers    Int      @default(0) @map("active_users")
  createdAt      DateTime @default(now()) @map("created_at")
  hotspotAddress String?  @db.VarChar(255) @map("hotspot_address")
  plans          Plan[]

  @@map("mikrotiks")
}

model Payment {
  id          Int       @id @default(autoincrement())
  planId      Int       @map("plan_id")
  email       String?   @db.VarChar(255)
  planName    String?   @db.VarChar(255) @map("plan_name")
  amount      Int
  status      String?   @db.VarChar(50)
  mpPaymentId BigInt?   @map("mp_payment_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  expiresAt   DateTime? @map("expires_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")
  mac         String?   @db.VarChar(20)
  cpf         String?   @db.VarChar(20)
  ip          String?   @db.VarChar(20)

  @@map("payments")
}

model Plan {
  id              Int      @id @default(autoincrement())
  name            String   @db.VarChar(100)
  description     String?  @db.Text
  amount          Decimal  @db.Decimal(10, 2)
  durationMinutes Int      @map("duration_minutes")
  downloadSpeed   String   @db.VarChar(20) @map("download_speed")
  uploadSpeed     String   @db.VarChar(20) @map("upload_speed")
  mikrotikId      Int      @map("mikrotik_id")
  active          Boolean  @default(true)
  addressPool     String   @default("default-dhcp") @db.VarChar(50) @map("address_pool")
  sharedUsers     Int      @default(10) @map("shared_users")
  mikrotik        Mikrotik @relation(fields: [mikrotikId], references: [id], onDelete: Cascade)

  @@map("plans")
}

// ── User (OTP authentication via WhatsApp) ───────────────────────────────────

model User {
  id        String    @id @default(uuid()) @db.Uuid
  cpf       String    @unique @db.VarChar(14)
  name      String?   @db.VarChar(100)
  phone     String?   @db.VarChar(20)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  otps      UserOtp[]

  @@index([cpf])
  @@index([phone])
  @@map("users")
}

model UserOtp {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid @map("user_id")
  hash      String   @db.VarChar(255)
  expiresAt DateTime @map("expires_at")
  attempts  Int      @default(0)
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([userId, createdAt])
  @@map("user_otps")
}

model RadiusUser {
  id        Int      @id @default(autoincrement())
  username  String   @db.VarChar(255)
  planId    Int?     @map("plan_id")
  nasId     Int?     @map("nas_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("radius_users")
}

model Radcheck {
  id        Int    @id @default(autoincrement())
  username  String @db.VarChar(64)
  attribute String @default("Cleartext-Password") @db.VarChar(64)
  op        String @default(":=") @db.Char(2)
  value     String @db.VarChar(253)

  @@map("radcheck")
}

model Radreply {
  id        Int    @id @default(autoincrement())
  username  String @db.VarChar(64)
  attribute String @db.VarChar(64)
  op        String @default(":=") @db.Char(2)
  value     String @db.VarChar(253)

  @@map("radreply")
}

model Radusergroup {
  username  String @db.VarChar(64)
  groupname String @db.VarChar(64)
  priority  Int    @default(1)

  @@id([username, groupname])
  @@map("radusergroup")
}

model OtpRequest {
  id          Int      @id @default(autoincrement())
  cpf         String   @db.VarChar(14)
  phone       String   @db.VarChar(20)
  otpHash     String   @db.VarChar(255) @map("otp_hash")
  expiresAt   DateTime @map("expires_at")
  attempts    Int      @default(0)
  maxAttempts Int      @default(5) @map("max_attempts")
  used        Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("otp_requests")
}

// ── OTP Audit Log (compliance / LGPD) ────────────────────────────────────────
//
// Records all relevant events from the OTP flow for audit and LGPD purposes.
//
// Recorded events:
//   otp_requested        – request received (start of flow)
//   otp_sent             – WhatsApp message sent successfully
//   otp_whatsapp_error   – WhatsApp delivery failure
//   otp_throttled        – blocked by recent request (rate-limit)
//   otp_validation_error – invalid CPF or phone number
//   otp_request_error    – generic request error
//   otp_verify_attempt   – verification attempt received
//   otp_verified         – OTP verified successfully
//   otp_invalid          – incorrect OTP code
//   otp_max_attempts     – maximum attempts reached (blocked)
//   otp_not_found        – no valid OTP found for user
//   otp_user_not_found   – CPF not found in the user database
//
// Minimal audit query:
//   -- All events for a CPF:
//   SELECT * FROM otp_audit_logs WHERE cpf = '<cpf>' ORDER BY created_at DESC;
//
//   -- Events in a date range:
//   SELECT event, COUNT(*) FROM otp_audit_logs
//     WHERE created_at BETWEEN '<start>' AND '<end>' GROUP BY event;
//
//   -- Blocked events in the last 24h:
//   SELECT cpf, ip, created_at FROM otp_audit_logs
//     WHERE event = 'otp_max_attempts'
//       AND created_at > NOW() - INTERVAL '24 hours'
//     ORDER BY created_at DESC;

model OtpAuditLog {
  id        Int      @id @default(autoincrement())
  event     String   @db.VarChar(50)
  cpf       String   @db.VarChar(14)
  phone     String?  @db.VarChar(20)
  ip        String?  @db.VarChar(45)
  detail    String?  @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([cpf])
  @@index([event])
  @@index([createdAt])
  @@map("otp_audit_logs")
}
