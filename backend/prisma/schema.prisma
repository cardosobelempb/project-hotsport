generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MemberRole {
  OWNER
  ADMIN
  OPERATOR
  HOTSPOT_USER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum OrganizationStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum AddressType {
  HOME
  WORK
  BILLING
  OTHER
}

enum Environment {
  SANDBOX
  PRODUCTION
}

enum MikrotikStatus {
  ONLINE
  OFFLINE
  ERROR
}

enum HotspotPlanType {
  TIME
  DATA
  UNLIMITED
}

enum HotspotUserStatus {
  ACTIVE
  EXPIRED
  BLOCKED
  PENDING
}

enum VoucherStatus {
  UNUSED
  ACTIVE
  EXPIRED
  REVOKED
}

enum ConsentStatus {
  ACTIVE
  REVOKED
  WITHDRAWN
}

enum PlanStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELED
  EXPIRED
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  YEARLY
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELED
  REFUNDED
}

model Organization {
  id        String             @id @default(uuid()) @db.Uuid
  name      String             @db.VarChar(100)
  slug      String             @unique @db.VarChar(100)
  logoUrl   String?            @map("logo_url") @db.VarChar(500)
  status    OrganizationStatus @default(ACTIVE)
  deletedAt DateTime?          @map("deleted_at")
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime?          @updatedAt @map("updated_at")

  members           Member[]
  mikrotiks         Mikrotik[]
  plans             HotspotPlan[]
  vouchers          Voucher[]
  hotspotUsers      HotspotUser[]
  lgpdConsents      LgpdConsent[]
  mpConfig          MercadoPagoConfig?
  efiConfig         EfiConfig?

  subscriptionPlans SubscriptionPlan[]
  subscriptions     Subscription[]
  payments          Payment[]

  @@index([slug])
  @@index([status])
  @@index([deletedAt])
  @@map("organization")
}

model Member {
  id             String     @id @default(uuid()) @db.Uuid
  organizationId String     @map("organization_id") @db.Uuid
  userId         String     @map("user_id") @db.Uuid
  role           MemberRole @default(OPERATOR)
  deletedAt      DateTime?  @map("deleted_at")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime?  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@index([deletedAt])
  @@map("member")
}

model User {
  id          String     @id @default(uuid()) @db.Uuid
  firstName   String     @map("first_name") @db.VarChar(100)
  lastName    String     @map("last_name") @db.VarChar(100)
  email       String     @unique @db.VarChar(255)
  cpf         String     @unique @db.VarChar(14)
  phoneNumber String?    @map("phone_number") @db.VarChar(20)
  status      UserStatus @default(ACTIVE)
  deletedAt   DateTime?  @map("deleted_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime?  @updatedAt @map("updated_at")

  accounts     Account[]
  tokens       Token[]
  members      Member[]
  addresses    Address[]
  otps         Otp[]
  lgpdConsents LgpdConsent[]

  @@index([email])
  @@index([cpf])
  @@index([phoneNumber])
  @@index([deletedAt])
  @@map("user")
}

model Address {
  id           String      @id @default(uuid()) @db.Uuid
  userId       String      @map("user_id") @db.Uuid
  type         AddressType @default(HOME)
  isPrimary    Boolean     @default(false) @map("is_primary")
  street       String      @db.VarChar(255)
  number       String      @db.VarChar(20)
  complement   String?     @db.VarChar(100)
  neighborhood String      @db.VarChar(100)
  city         String      @db.VarChar(100)
  state        String      @db.Char(2)
  country      String      @default("BR") @db.Char(2)
  zipCode      String      @map("zip_code") @db.VarChar(10)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime?   @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("address")
}

model Account {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @db.Uuid
  provider          String    @db.VarChar(50)
  providerAccountId String    @map("provider_account_id")
  passwordHash      String?   @map("password_hash")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime? @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("account")
}

model Token {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @db.Uuid
  refreshToken String    @map("refresh_token")
  accessToken  String    @map("access_token")
  expiresAt    DateTime
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime? @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("token")
}

model Otp {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String?   @map("user_id") @db.Uuid
  phone     String    @db.VarChar(30)
  codeHash  String    @map("code_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at")
  attempts  Int       @default(0)
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phone])
  @@index([userId])
  @@index([expiresAt])
  @@map("otp")
}

model MercadoPagoConfig {
  id                   Int       @id @default(autoincrement())
  organizationId       String    @unique @db.Uuid
  publicKey            String?   @map("public_key")
  accessTokenEncrypted String?   @map("access_token")
  clientId             String?   @map("client_id")
  clientSecret         String?   @map("client_secret")
  webhookSecret        String?
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime? @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("config_mercadopago")
}

model EfiConfig {
  id             Int         @id @default(autoincrement())
  organizationId String      @unique @db.Uuid
  clientId       String
  clientSecret   String
  pixKey         String
  environment    Environment @default(SANDBOX)
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime?   @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("efi_config")
}

model Mikrotik {
  id             String         @id @default(uuid()) @db.Uuid
  organizationId String         @db.Uuid
  name           String
  host           String
  port           Int            @default(8728)
  macAddress     String         @map("mac_address") @db.VarChar(20)
  ipAddress      String         @map("ip_address") @db.VarChar(15)
  username       String
  passwordHash   String
  status         MikrotikStatus @default(OFFLINE)
  deletedAt      DateTime?      @map("deleted_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime?      @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vouchers     Voucher[]
  hotspotUsers HotspotUser[]

  @@index([organizationId])
  @@index([host])
  @@index([deletedAt])
  @@map("mikrotik")
}

model HotspotPlan {
  id             String          @id @default(uuid()) @db.Uuid
  organizationId String          @db.Uuid
  name           String
  type           HotspotPlanType @default(TIME)
  durationSecs   Int?
  dataLimitMb    Int?
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime?       @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vouchers     Voucher[]

  @@index([organizationId])
  @@map("hotspot_plan")
}

model HotspotUser {
  id             String            @id @default(uuid()) @db.Uuid
  organizationId String            @db.Uuid
  mikrotikId     String            @db.Uuid
  username       String
  macAddress     String            @map("mac_address") @db.VarChar(20)
  ipAddress      String            @map("ip_address") @db.VarChar(15)
  passwordHash   String
  status         HotspotUserStatus @default(PENDING)
  deletedAt      DateTime?         @map("deleted_at")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime?         @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  mikrotik     Mikrotik     @relation(fields: [mikrotikId], references: [id], onDelete: Cascade)

  @@unique([organizationId, username])
  @@index([organizationId, status])
  @@index([macAddress])
  @@index([deletedAt])
  @@map("hotspot_user")
}

model Voucher {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  mikrotikId     String        @map("mikrotik_id") @db.Uuid
  planId         String        @map("plan_id") @db.Uuid
  code           String        @unique @db.VarChar(20)
  status         VoucherStatus @default(UNUSED)
  usedAt         DateTime?     @map("used_at")
  expiresAt      DateTime?     @map("expires_at")
  deletedAt      DateTime?     @map("deleted_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime?     @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  mikrotik     Mikrotik     @relation(fields: [mikrotikId], references: [id], onDelete: Cascade)
  plan         HotspotPlan  @relation(fields: [planId], references: [id])

  @@index([organizationId, status])
  @@index([expiresAt])
  @@index([deletedAt])
  @@map("voucher")
}

model LgpdConsent {
  id                 String        @id @default(uuid()) @db.Uuid
  userId             String        @map("user_id") @db.Uuid
  organizationId     String        @map("organization_id") @db.Uuid
  consentTerms       Boolean       @map("consent_terms")
  consentMarketing   Boolean       @map("consent_marketing")
  consentDataSharing Boolean       @map("consent_data_sharing")
  consentAnalytics   Boolean       @map("consent_analytics")
  ipAddress          String        @map("ip_address") @db.VarChar(45)
  macAddress         String        @map("mac_address") @db.VarChar(20)
  userAgent          String        @map("user_agent") @db.VarChar(500)
  consentVersion     String        @map("consent_version") @db.VarChar(10)
  status             ConsentStatus @default(ACTIVE)
  withdrawnAt        DateTime?     @map("withdrawn_at")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime?     @updatedAt @map("updated_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId, consentVersion])
  @@index([userId])
  @@index([organizationId])
  @@index([status])
  @@map("lgpd_consent")
}

model SubscriptionPlan {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String?      @map("organization_id") @db.Uuid
  code           String       @db.VarChar(50)
  name           String       @db.VarChar(120)
  description    String?      @db.VarChar(500)
  status         PlanStatus   @default(ACTIVE)
  billingCycle   BillingCycle @map("billing_cycle")
  amount         Decimal      @db.Decimal(12, 2)
  currency       String       @db.VarChar(3)
  trialDays      Int?         @map("trial_days")
  sortOrder      Int          @default(0) @map("sort_order")
  isPublic       Boolean      @default(true) @map("is_public")
  isDefault      Boolean      @default(false) @map("is_default")
  deletedAt      DateTime?    @map("deleted_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime?    @updatedAt @map("updated_at")

  organization  Organization?  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([status])
  @@index([isPublic])
  @@index([isDefault])
  @@index([deletedAt])
  @@map("subscription_plan")
}

model Subscription {
  id                 String             @id @default(uuid()) @db.Uuid
  organizationId     String             @map("organization_id") @db.Uuid
  subscriptionPlanId String             @map("subscription_plan_id") @db.Uuid
  status             SubscriptionStatus @default(ACTIVE)
  billingCycle       BillingCycle       @map("billing_cycle")
  amount             Decimal            @db.Decimal(12, 2)
  currency           String             @db.VarChar(3)
  trialStartsAt      DateTime?          @map("trial_starts_at")
  trialEndsAt        DateTime?          @map("trial_ends_at")
  startsAt           DateTime           @map("starts_at")
  currentPeriodStart DateTime           @map("current_period_start")
  currentPeriodEnd   DateTime           @map("current_period_end")
  canceledAt         DateTime?          @map("canceled_at")
  expiresAt          DateTime?          @map("expires_at")
  deletedAt          DateTime?          @map("deleted_at")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime?          @updatedAt @map("updated_at")

  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscriptionPlan SubscriptionPlan @relation(fields: [subscriptionPlanId], references: [id], onDelete: Restrict)
  payments         Payment[]

  @@index([organizationId])
  @@index([subscriptionPlanId])
  @@index([status])
  @@index([currentPeriodEnd])
  @@index([deletedAt])
  @@map("subscription")
}

model Payment {
  id                    String        @id @default(uuid()) @db.Uuid
  organizationId        String        @map("organization_id") @db.Uuid
  subscriptionId        String        @map("subscription_id") @db.Uuid
  amount                Decimal       @db.Decimal(12, 2)
  currency              String        @db.VarChar(3)
  status                PaymentStatus @default(PENDING)
  provider              String?       @db.VarChar(50)
  providerTransactionId String?       @map("provider_transaction_id") @db.VarChar(255)
  description           String?       @db.VarChar(255)
  dueAt                 DateTime?     @map("due_at")
  paidAt                DateTime?     @map("paid_at")
  failedAt              DateTime?     @map("failed_at")
  refundedAt            DateTime?     @map("refunded_at")
  deletedAt             DateTime?     @map("deleted_at")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime?     @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([subscriptionId])
  @@index([status])
  @@index([providerTransactionId])
  @@index([dueAt])
  @@index([deletedAt])
  @@map("payment")
}
