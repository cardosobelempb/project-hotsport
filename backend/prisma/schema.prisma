generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id         Int      @id @default(autoincrement())
  email      String   @unique @db.VarChar(255)
  password   String   @db.VarChar(255)
  created_at DateTime @default(now())

  @@map("admins")
}

model ConfigMercadoPago {
  id             Int      @id @default(autoincrement())
  public_key     String?  @db.VarChar(255)
  access_token   String?  @db.Text
  client_id      String?  @db.VarChar(255)
  client_secret  String?  @db.Text
  webhook_secret String?  @db.VarChar(255)
  updated_at     DateTime @default(now()) @updatedAt

  @@map("config_mercadopago")
}

model EfiConfig {
  id                Int      @id @default(autoincrement())
  client_id         String   @db.VarChar(255)
  client_secret     String   @db.VarChar(255)
  chave_pix         String   @db.VarChar(255)
  ambiente          Ambiente @default(sandbox)
  certificado_nome  String?  @db.VarChar(255)
  criado_em         DateTime @default(now())

  @@map("efi_config")
}

enum Ambiente {
  sandbox
  producao
}

model LgpdLogin {
  id        Int      @id @default(autoincrement())
  cpf       String   @db.VarChar(14)
  aceite    Boolean  @default(false)
  mac       String?  @db.VarChar(50)
  ip        String?  @db.VarChar(50)
  criado_em DateTime @default(now())
  nome      String?  @db.VarChar(100)
  telefone  String?  @db.VarChar(20)

  @@map("lgpd_logins")
}

model Mikrotik {
  id              Int       @id @default(autoincrement())
  nome            String    @db.VarChar(100)
  ip              String    @db.VarChar(45)
  usuario         String    @db.VarChar(100)
  senha           String    @db.VarChar(255)
  porta           Int       @default(8728)
  status          String    @default("Offline") @db.VarChar(20)
  usuarios_ativos Int       @default(0)
  criado_em       DateTime  @default(now())
  end_hotspot     String?   @db.VarChar(255)
  planos          Plano[]

  @@map("mikrotiks")
}

model Pagamento {
  id             Int       @id @default(autoincrement())
  plano_id       Int
  email          String?   @db.VarChar(255)
  nome_plano     String?   @db.VarChar(255)
  valor          Int
  status         String?   @db.VarChar(50)
  mp_pagamento_id BigInt?
  criado_em      DateTime  @default(now())
  expira_em      DateTime?
  atualizado_em  DateTime  @default(now()) @updatedAt
  mac            String?   @db.VarChar(20)
  cpf            String?   @db.VarChar(20)
  IP             String?   @db.VarChar(20)

  @@map("pagamentos")
}

model Plano {
  id               Int      @id @default(autoincrement())
  nome             String   @db.VarChar(100)
  descricao        String?  @db.Text
  valor            Decimal  @db.Decimal(10, 2)
  duracao_minutos  Int
  velocidade_down  String   @db.VarChar(20)
  velocidade_up    String   @db.VarChar(20)
  mikrotik_id      Int
  ativo            Boolean  @default(true)
  address_pool     String   @default("default-dhcp") @db.VarChar(50)
  shared_users     Int      @default(10)
  mikrotik         Mikrotik @relation(fields: [mikrotik_id], references: [id], onDelete: Cascade)

  @@map("planos")
}

// ── User (autenticação OTP via WhatsApp) ─────────────────────────────────────

model User {
  id         String    @id @default(uuid()) @db.Uuid
  cpf        String    @unique @db.VarChar(14)
  name       String?   @db.VarChar(100)
  phone      String?   @db.VarChar(20)
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  otps       UserOtp[]

  @@index([cpf])
  @@map("users")
}

model UserOtp {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String   @db.Uuid
  hash       String   @db.VarChar(255)
  expires_at DateTime
  attempts   Int      @default(0)
  used       Boolean  @default(false)
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([expires_at])
  @@map("user_otps")
}

model RadiusUser {
  id         Int      @id @default(autoincrement())
  username   String   @db.VarChar(255)
  plano_id   Int?
  nas_id     Int?
  criado_em  DateTime @default(now())

  @@map("radius_users")
}

model Radcheck {
  id        Int    @id @default(autoincrement())
  username  String @db.VarChar(64)
  attribute String @default("Cleartext-Password") @db.VarChar(64)
  op        String @default(":=") @db.Char(2)
  value     String @db.VarChar(253)

  @@map("radcheck")
}

model Radreply {
  id        Int    @id @default(autoincrement())
  username  String @db.VarChar(64)
  attribute String @db.VarChar(64)
  op        String @default(":=") @db.Char(2)
  value     String @db.VarChar(253)

  @@map("radreply")
}

model Radusergroup {
  username  String @db.VarChar(64)
  groupname String @db.VarChar(64)
  priority  Int    @default(1)

  @@id([username, groupname])
  @@map("radusergroup")
}

model OtpRequest {
  id           Int      @id @default(autoincrement())
  cpf          String   @db.VarChar(14)
  telefone     String   @db.VarChar(20)
  otp_hash     String   @db.VarChar(255)
  expires_at   DateTime
  attempts     Int      @default(0)
  max_attempts Int      @default(5)
  used         Boolean  @default(false)
  criado_em    DateTime @default(now())

  @@map("otp_requests")
}

// ── OTP Audit Log (compliance / LGPD) ────────────────────────────────────────
//
// Registra todos os eventos relevantes do fluxo OTP para auditoria e LGPD.
//
// Eventos registrados:
//   otp_requested        – solicitação recebida (início do fluxo)
//   otp_sent             – mensagem WhatsApp enviada com sucesso
//   otp_whatsapp_error   – falha no envio via WhatsApp
//   otp_throttled        – bloqueio por solicitação recente (rate-limit)
//   otp_validation_error – CPF ou telefone inválido
//   otp_request_error    – erro genérico na solicitação
//   otp_verify_attempt   – tentativa de verificação recebida
//   otp_verified         – OTP verificado com sucesso
//   otp_invalid          – código OTP incorreto
//   otp_max_attempts     – número máximo de tentativas atingido (bloqueio)
//   otp_not_found        – nenhum OTP válido encontrado para o usuário
//   otp_user_not_found   – CPF não encontrado na base de usuários
//
// Query mínima para auditoria:
//   -- Todos os eventos de um CPF:
//   SELECT * FROM otp_audit_logs WHERE cpf = '<cpf>' ORDER BY criado_em DESC;
//
//   -- Eventos em intervalo de datas:
//   SELECT event, COUNT(*) FROM otp_audit_logs
//     WHERE criado_em BETWEEN '<inicio>' AND '<fim>' GROUP BY event;
//
//   -- Detecção de bloqueios nas últimas 24h:
//   SELECT cpf, ip, criado_em FROM otp_audit_logs
//     WHERE event = 'otp_max_attempts'
//       AND criado_em > NOW() - INTERVAL '24 hours'
//     ORDER BY criado_em DESC;

model OtpAuditLog {
  id        Int      @id @default(autoincrement())
  event     String   @db.VarChar(50)
  cpf       String   @db.VarChar(14)
  telefone  String?  @db.VarChar(20)
  ip        String?  @db.VarChar(45)
  detail    String?  @db.VarChar(500)
  criado_em DateTime @default(now())

  @@index([cpf])
  @@index([event])
  @@index([criado_em])
  @@map("otp_audit_logs")
}
