generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
  OPERATOR
  HOTSPOT_USER
}

enum MemberInvitationStatus {
  ACTIVE
  ACCEPTED
  DECLINED
  EXPIRED
  INVITED
  PENDING
  REMOVED
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum AccountType {
  PASSWORD
  OAUTH
  OTP
}

enum AccountProvider {
  EMAIL
  GOOGLE
  FACEBOOK
  APPLE
}

enum TokenType {
  REFRESH
  ACCESS
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum OrganizationStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum AddressType {
  HOME
  WORK
  BILLING
  OTHER
}

enum Environment {
  SANDBOX
  PRODUCTION
}

enum MikrotikStatus {
  ONLINE
  OFFLINE
  ERROR
}

enum HotspotPlanType {
  TIME
  DATA
  UNLIMITED
}

enum HotspotUserStatus {
  ACTIVE
  EXPIRED
  BLOCKED
  PENDING
}

enum VoucherStatus {
  UNUSED
  ACTIVE
  EXPIRED
  REVOKED
}

enum ConsentStatus {
  ACTIVE
  REVOKED
  WITHDRAWN
}

enum PlanStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELED
  EXPIRED
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  YEARLY
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELED
  REFUNDED
}

enum CampaignItemType {
  IMAGE @map("imagem")
  VIDEO @map("video")
}

enum OrganizationConfigType {
  MERCADOPAGO @map("mercadopago")
  EFI         @map("efi")
  WHATSAPP    @map("whatsapp")
}

enum LeadStatus {
  NEW       @map("novo")
  CONTACTED @map("contactado")
  CONVERTED @map("convertido")
  DISCARDED @map("descartado")
}

enum UpdateFileAction {
  CREATE @map("create")
  UPDATE @map("update")
  DELETE @map("delete")
}

enum UpdateApplyLogStatus {
  INFO  @map("info")
  OK    @map("ok")
  ERROR @map("erro")
}

enum SystemBackupType {
  PRE_UPDATE @map("pre_update")
  MANUAL     @map("manual")
}

enum WhatsappLogStatus {
  OK      @map("ok")
  ERROR   @map("erro")
  SKIPPED @map("skipped")
}

model Organization {
  id        String             @id @default(uuid()) @db.Uuid
  name      String             @db.VarChar(100)
  slug      String             @unique @db.VarChar(100)
  logoUrl   String?            @map("logo_url") @db.VarChar(500)
  status    OrganizationStatus @default(ACTIVE)
  deletedAt DateTime?          @map("deleted_at")
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime?          @updatedAt @map("updated_at")

  members      Member[]
  mikrotiks    Mikrotik[]
  plans        HotspotPlan[]
  vouchers     Voucher[]
  hotspotUsers HotspotUser[]
  lgpdConsents LgpdConsent[]
  mpConfig     MercadoPagoConfig?
  efiConfig    EfiConfig?

  subscriptionPlans   SubscriptionPlan[]
  subscriptions       Subscription[]
  payments            Payment[]
  campaigns           Campaign[]
  campaignItems       CampaignItem[]
  organizationConfigs OrganizationConfig[]
  vpnPeers            OrganizationVpnPeer[]
  portals             Portal[]
  leads               Lead[]
  connectionLogs      ConnectionLog[]
  whatsappLogs        WhatsappLog[]

  @@index([slug])
  @@index([status])
  @@index([deletedAt])
  @@map("organization")
}

model Member {
  id               String                 @id @default(uuid()) @db.Uuid
  organizationId   String                 @map("organization_id") @db.Uuid
  userId           String                 @map("user_id") @db.Uuid
  role             MemberRole             @default(OPERATOR)
  status           MemberStatus           @default(ACTIVE)
  email            String                 @db.VarChar(255)
  invitationStatus MemberInvitationStatus @default(PENDING) @map("invitation_status")
  joinedAt         DateTime               @default(now()) @map("joined_at")
  invitedBy        String?                @map("invited_by") @db.Uuid
  expiresAt        DateTime?              @map("expires_at")
  deletedAt        DateTime?              @map("deleted_at")
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime?              @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@index([deletedAt])
  @@map("member")
}

model User {
  id          String     @id @default(uuid()) @db.Uuid
  firstName   String     @map("first_name") @db.VarChar(100)
  lastName    String     @map("last_name") @db.VarChar(100)
  email       String     @unique @db.VarChar(255)
  cpf         String     @unique @db.VarChar(14)
  phoneNumber String?    @map("phone_number") @db.VarChar(20)
  status      UserStatus @default(ACTIVE)
  deletedAt   DateTime?  @map("deleted_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime?  @updatedAt @map("updated_at")

  accounts     Account[]
  tokens       Token[]
  members      Member[]
  addresses    Address[]
  otps         Otp[]
  lgpdConsents LgpdConsent[]

  @@index([email])
  @@index([cpf])
  @@index([phoneNumber])
  @@index([deletedAt])
  @@map("user")
}

model Address {
  id           String      @id @default(uuid()) @db.Uuid
  userId       String      @map("user_id") @db.Uuid
  type         AddressType @default(HOME)
  isPrimary    Boolean     @default(false) @map("is_primary")
  street       String      @db.VarChar(255)
  number       String      @db.VarChar(20)
  complement   String?     @db.VarChar(100)
  neighborhood String      @db.VarChar(100)
  city         String      @db.VarChar(100)
  state        String      @db.Char(2)
  country      String      @default("BR") @db.Char(2)
  zipCode      String      @map("zip_code") @db.VarChar(10)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime?   @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("address")
}

model Account {
  id                String          @id @default(uuid()) @db.Uuid
  userId            String          @db.Uuid
  provider          AccountProvider @default(EMAIL)
  type              AccountType     @default(PASSWORD)
  providerAccountId String          @map("provider_account_id")
  passwordHash      String?         @map("password_hash")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime?       @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("account")
}

model Token {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  token     TokenType @default(ACCESS)
  expiresAt DateTime
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("token")
}

model Otp {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String?   @map("user_id") @db.Uuid
  phone     String    @db.VarChar(30)
  codeHash  String    @map("code_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at")
  attempts  Int       @default(0)
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phone])
  @@index([userId])
  @@index([expiresAt])
  @@map("otp")
}

model MercadoPagoConfig {
  id                   String    @id @default(uuid()) @db.Uuid
  organizationId       String    @unique @db.Uuid
  publicKey            String?   @map("public_key")
  accessTokenEncrypted String?   @map("access_token")
  clientId             String?   @map("client_id")
  clientSecret         String?   @map("client_secret")
  webhookSecret        String?
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime? @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("config_mercadopago")
}

model EfiConfig {
  id             String      @id @default(uuid()) @db.Uuid
  organizationId String      @unique @db.Uuid
  clientId       String
  clientSecret   String
  pixKey         String
  environment    Environment @default(SANDBOX)
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime?   @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("efi_config")
}

model Mikrotik {
  id             String         @id @default(uuid()) @db.Uuid
  organizationId String         @db.Uuid
  name           String
  host           String
  port           Int            @default(8728)
  macAddress     String         @map("mac_address") @db.VarChar(20)
  ipAddress      String         @map("ip_address") @db.VarChar(15)
  username       String
  passwordHash   String
  activeUser     Boolean        @default(false) @map("active_user")
  status         MikrotikStatus @default(OFFLINE)
  deletedAt      DateTime?      @map("deleted_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime?      @updatedAt @map("updated_at")

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vouchers     Voucher[]
  hotspotUsers HotspotUser[]

  @@index([organizationId])
  @@index([host])
  @@index([deletedAt])
  @@map("mikrotik")
}

model HotspotPlan {
  id             String          @id @default(uuid()) @db.Uuid
  organizationId String          @db.Uuid
  name           String
  type           HotspotPlanType @default(TIME)
  durationSecs   Int?
  dataLimitMb    Int?
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime?       @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vouchers     Voucher[]

  @@index([organizationId])
  @@map("hotspot_plan")
}

model HotspotUser {
  id             String            @id @default(uuid()) @db.Uuid
  organizationId String            @db.Uuid
  mikrotikId     String            @db.Uuid
  username       String
  macAddress     String            @map("mac_address") @db.VarChar(20)
  ipAddress      String            @map("ip_address") @db.VarChar(15)
  passwordHash   String
  status         HotspotUserStatus @default(PENDING)
  deletedAt      DateTime?         @map("deleted_at")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime?         @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  mikrotik     Mikrotik     @relation(fields: [mikrotikId], references: [id], onDelete: Cascade)

  @@unique([organizationId, username])
  @@index([organizationId, status])
  @@index([macAddress])
  @@index([deletedAt])
  @@map("hotspot_user")
}

model Voucher {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  mikrotikId     String        @map("mikrotik_id") @db.Uuid
  planId         String        @map("plan_id") @db.Uuid
  code           String        @unique @db.VarChar(20)
  status         VoucherStatus @default(UNUSED)
  usedAt         DateTime?     @map("used_at")
  expiresAt      DateTime?     @map("expires_at")
  deletedAt      DateTime?     @map("deleted_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime?     @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  mikrotik     Mikrotik     @relation(fields: [mikrotikId], references: [id], onDelete: Cascade)
  plan         HotspotPlan  @relation(fields: [planId], references: [id])

  @@index([organizationId, status])
  @@index([expiresAt])
  @@index([deletedAt])
  @@map("voucher")
}

model LgpdConsent {
  id                 String        @id @default(uuid()) @db.Uuid
  userId             String        @map("user_id") @db.Uuid
  organizationId     String        @map("organization_id") @db.Uuid
  consentTerms       Boolean       @map("consent_terms")
  consentMarketing   Boolean       @map("consent_marketing")
  consentDataSharing Boolean       @map("consent_data_sharing")
  consentAnalytics   Boolean       @map("consent_analytics")
  ipAddress          String        @map("ip_address") @db.VarChar(45)
  macAddress         String        @map("mac_address") @db.VarChar(20)
  userAgent          String        @map("user_agent") @db.VarChar(500)
  consentVersion     String        @map("consent_version") @db.VarChar(10)
  status             ConsentStatus @default(ACTIVE)
  withdrawnAt        DateTime?     @map("withdrawn_at")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime?     @updatedAt @map("updated_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId, consentVersion])
  @@index([userId])
  @@index([organizationId])
  @@index([status])
  @@map("lgpd_consent")
}

model SubscriptionPlan {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String?      @map("organization_id") @db.Uuid
  code           String       @db.VarChar(50)
  name           String       @db.VarChar(120)
  description    String?      @db.VarChar(500)
  status         PlanStatus   @default(ACTIVE)
  billingCycle   BillingCycle @map("billing_cycle")
  amount         Decimal      @db.Decimal(12, 2)
  currency       String       @db.VarChar(3)
  trialDays      Int?         @map("trial_days")
  sortOrder      Int          @default(0) @map("sort_order")
  isPublic       Boolean      @default(true) @map("is_public")
  isDefault      Boolean      @default(false) @map("is_default")
  deletedAt      DateTime?    @map("deleted_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime?    @updatedAt @map("updated_at")

  organization  Organization?  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([status])
  @@index([isPublic])
  @@index([isDefault])
  @@index([deletedAt])
  @@map("subscription_plan")
}

model Subscription {
  id                 String             @id @default(uuid()) @db.Uuid
  organizationId     String             @map("organization_id") @db.Uuid
  subscriptionPlanId String             @map("subscription_plan_id") @db.Uuid
  status             SubscriptionStatus @default(ACTIVE)
  billingCycle       BillingCycle       @map("billing_cycle")
  amount             Decimal            @db.Decimal(12, 2)
  currency           String             @db.VarChar(3)
  trialStartsAt      DateTime?          @map("trial_starts_at")
  trialEndsAt        DateTime?          @map("trial_ends_at")
  startsAt           DateTime           @map("starts_at")
  currentPeriodStart DateTime           @map("current_period_start")
  currentPeriodEnd   DateTime           @map("current_period_end")
  canceledAt         DateTime?          @map("canceled_at")
  expiresAt          DateTime?          @map("expires_at")
  deletedAt          DateTime?          @map("deleted_at")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime?          @updatedAt @map("updated_at")

  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscriptionPlan SubscriptionPlan @relation(fields: [subscriptionPlanId], references: [id], onDelete: Restrict)
  payments         Payment[]

  @@index([organizationId])
  @@index([subscriptionPlanId])
  @@index([status])
  @@index([currentPeriodEnd])
  @@index([deletedAt])
  @@map("subscription")
}

model Payment {
  id                    String        @id @default(uuid()) @db.Uuid
  organizationId        String        @map("organization_id") @db.Uuid
  subscriptionId        String        @map("subscription_id") @db.Uuid
  amount                Decimal       @db.Decimal(12, 2)
  currency              String        @db.VarChar(3)
  status                PaymentStatus @default(PENDING)
  provider              String?       @db.VarChar(50)
  providerTransactionId String?       @map("provider_transaction_id") @db.VarChar(255)
  description           String?       @db.VarChar(255)
  dueAt                 DateTime?     @map("due_at")
  paidAt                DateTime?     @map("paid_at")
  failedAt              DateTime?     @map("failed_at")
  refundedAt            DateTime?     @map("refunded_at")
  deletedAt             DateTime?     @map("deleted_at")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime?     @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([subscriptionId])
  @@index([status])
  @@index([providerTransactionId])
  @@index([dueAt])
  @@index([deletedAt])
  @@map("payment")
}

model Campaign {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  name           String    @db.VarChar(150)
  description    String?
  isActive       Boolean   @default(true) @map("is_active")
  views          Int       @default(0)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime? @updatedAt @map("updated_at")

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items        CampaignItem[]
  portals      Portal[]

  @@index([organizationId])
  @@map("campaign")
}

model CampaignItem {
  id              String           @id @default(uuid()) @db.Uuid
  campaignId      String           @map("campaign_id") @db.Uuid
  organizationId  String           @map("organization_id") @db.Uuid
  type            CampaignItemType
  order           Int              @default(0)
  fileUrl         String           @map("file_url") @db.VarChar(500)
  durationSeconds Int              @default(5) @map("duration_seconds")
  title           String?          @db.VarChar(200)
  destinationLink String?          @map("destination_link") @db.VarChar(500)
  createdAt       DateTime         @default(now()) @map("created_at")

  campaign     Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([campaignId, order])
  @@index([organizationId])
  @@map("campaign_item")
}

model OrganizationConfig {
  id             String                 @id @default(uuid()) @db.Uuid
  organizationId String                 @map("organization_id") @db.Uuid
  configType     OrganizationConfigType @map("config_type")
  configJson     Json                   @map("config_json")
  isActive       Boolean                @default(true) @map("is_active")
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime?              @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, configType])
  @@map("organization_config")
}

model OrganizationVpnPeer {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  wgClientId     String   @map("wg_client_id") @db.VarChar(100)
  name           String?  @db.VarChar(100)
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([wgClientId])
  @@map("organization_vpn_peer")
}

model Portal {
  id               String  @id @default(uuid()) @db.Uuid
  organizationId   String? @map("organization_id") @db.Uuid
  activeCampaignId String? @map("active_campaign_id") @db.Uuid
  templateId       String? @map("template_id") @db.Uuid

  name               String   @db.VarChar(100)
  slug               String   @db.VarChar(50)
  type               String?  @default("basico") @db.VarChar(50)
  redirectUrl        String?  @map("redirect_url") @db.VarChar(500)
  htmlContent        String?  @map("html_content")
  description        String?
  isActive           Boolean  @default(true) @map("is_active")
  customCss          String?  @map("custom_css")
  logoUrl            String?  @map("logo_url") @db.VarChar(500)
  primaryColor       String?  @default("#3B82F6") @map("primary_color") @db.VarChar(7)
  backgroundColor    String?  @default("#0f111a") @map("background_color") @db.VarChar(7)
  registrationFields Json?    @map("registration_fields")
  showPlans          Boolean  @default(false) @map("show_plans")
  showLgpd           Boolean  @default(true) @map("show_lgpd")
  settings           String?
  whatsappEnabled    Boolean  @default(false) @map("whatsapp_enabled")
  whatsappTemplate   String?  @map("whatsapp_template")
  createdAt          DateTime @default(now()) @map("created_at")

  organization   Organization?   @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  activeCampaign Campaign?       @relation(fields: [activeCampaignId], references: [id], onDelete: SetNull)
  template       PortalTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  whatsappLogs   WhatsappLog[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([activeCampaignId])
  @@map("portal")
}

model PortalTemplate {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @db.VarChar(255)
  description  String?
  thumbnailUrl String?  @map("thumbnail_url") @db.VarChar(500)
  htmlTemplate String   @map("html_template")
  cssTemplate  String?  @map("css_template")
  type         String?  @default("basico") @db.VarChar(50)
  createdAt    DateTime @default(now()) @map("created_at")

  portals Portal[]

  @@map("portal_template")
}

model Lead {
  id             String     @id @default(uuid()) @db.Uuid
  organizationId String     @map("organization_id") @db.Uuid
  name           String?    @db.VarChar(255)
  email          String?    @db.VarChar(255)
  phone          String?    @db.VarChar(50)
  cpf            String?    @db.VarChar(20)
  mac            String?    @db.VarChar(50)
  ip             String?    @db.VarChar(50)
  status         LeadStatus @default(NEW)
  source         String?    @default("portal") @db.VarChar(50)
  observations   String?
  lgpdAccepted   Boolean    @default(false) @map("lgpd_accepted")
  lgpdAcceptedAt DateTime?  @map("lgpd_accepted_at")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime?  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("lead")
}

model ConnectionLog {
  id                String    @id @default(uuid()) @db.Uuid
  organizationId    String    @map("organization_id") @db.Uuid
  username          String    @db.VarChar(64)
  cpf               String?   @db.VarChar(14)
  mac               String    @db.VarChar(50)
  assignedIp        String    @map("assigned_ip") @db.VarChar(45)
  nasIp             String    @map("nas_ip") @db.VarChar(45)
  connectionStartAt DateTime  @map("connection_start_at")
  connectionEndAt   DateTime? @map("connection_end_at")
  inputBytes        BigInt    @default(0) @map("input_bytes")
  outputBytes       BigInt    @default(0) @map("output_bytes")
  durationSeconds   Int       @default(0) @map("duration_seconds")
  disconnectReason  String?   @map("disconnect_reason") @db.VarChar(32)
  authResult        String?   @map("auth_result") @db.VarChar(32)
  createdAt         DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([cpf])
  @@index([mac])
  @@index([assignedIp])
  @@index([connectionStartAt, connectionEndAt])
  @@index([username])
  @@map("connection_log")
}

model WhatsappLog {
  id             String            @id @default(uuid()) @db.Uuid
  organizationId String            @map("organization_id") @db.Uuid
  portalId       String?           @map("portal_id") @db.Uuid
  phone          String?           @db.VarChar(20)
  message        String?
  contextType    String?           @map("context_type") @db.VarChar(50)
  referenceId    String?           @map("reference_id") @db.Uuid
  status         WhatsappLogStatus
  errorMessage   String?           @map("error_message")
  skipReason     String?           @map("skip_reason") @db.VarChar(50)
  createdAt      DateTime          @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  portal       Portal?      @relation(fields: [portalId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([status])
  @@index([portalId])
  @@map("whatsapp_log")
}

model Update {
  id          String   @id @db.VarChar(20)
  description String?
  changelog   String?
  createdAt   DateTime @default(now()) @map("created_at")

  files      UpdateFile[]
  migrations UpdateMigration[]

  @@map("update")
}

model AppliedUpdate {
  id          String   @id @db.VarChar(20)
  description String?
  appliedAt   DateTime @default(now()) @map("applied_at")

  @@map("applied_update")
}

model UpdateFile {
  id          String            @id @default(uuid()) @db.Uuid
  updateId    String?           @map("update_id") @db.VarChar(20)
  filePath    String?           @map("file_path") @db.VarChar(500)
  fileContent String?           @map("file_content")
  action      UpdateFileAction? @default(UPDATE)

  update Update? @relation(fields: [updateId], references: [id], onDelete: Cascade)

  @@index([updateId])
  @@map("update_file")
}

model UpdateMigration {
  id         String  @id @default(uuid()) @db.Uuid
  updateId   String? @map("update_id") @db.VarChar(20)
  sqlContent String? @map("sql_content")
  order      Int?    @default(1)

  update Update? @relation(fields: [updateId], references: [id], onDelete: Cascade)

  @@index([updateId])
  @@map("update_migration")
}

model UpdateApplyLog {
  id        String               @id @default(uuid()) @db.Uuid
  updateId  String               @map("update_id") @db.VarChar(20)
  step      String               @db.VarChar(50)
  status    UpdateApplyLogStatus @default(INFO)
  message   String?
  createdAt DateTime             @default(now()) @map("created_at")

  @@index([updateId])
  @@index([createdAt])
  @@map("update_apply_log")
}

model FileSnapshot {
  id           String   @id @default(uuid()) @db.Uuid
  filePath     String?  @unique @map("file_path") @db.VarChar(500)
  md5Hash      String?  @map("md5_hash") @db.VarChar(32)
  snapshotDate DateTime @default(now()) @map("snapshot_date")

  @@map("file_snapshot")
}

model SchemaSnapshot {
  tableName    String   @id @map("table_name") @db.VarChar(128)
  columnsJson  String   @map("columns_json")
  indexesJson  String   @map("indexes_json")
  createSql    String?  @map("create_sql")
  snapshotDate DateTime @updatedAt @map("snapshot_date")

  @@map("schema_snapshot")
}

model SystemBackup {
  id           String            @id @default(uuid()) @db.Uuid
  updateId     String?           @map("update_id") @db.VarChar(20)
  type         SystemBackupType? @default(MANUAL)
  dbDumpPath   String?           @map("db_dump_path") @db.VarChar(500)
  filesZipPath String?           @map("files_zip_path") @db.VarChar(500)
  createdAt    DateTime          @default(now()) @map("created_at")

  @@map("system_backup")
}
