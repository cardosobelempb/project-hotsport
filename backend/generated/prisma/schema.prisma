generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// ORGANIZAÇÃO (tenant)
// ─────────────────────────────────────────────────────────────────────────────

model Organization {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @db.VarChar(100)
  slug      String    @unique @db.VarChar(100)
  logoUrl   String?   @map("logo_url") @db.VarChar(500)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  members      Member[]
  mikrotiks    Mikrotik[]
  plans        HotspotPlan[]
  vouchers     Voucher[]
  hotspotUsers HotspotUser[]
  lgpdConsents LgpdConsent[]

  @@index([slug])
  @@map("organization")
}

// ─────────────────────────────────────────────────────────────────────────────
// MEMBRO (usuário dentro de uma organização com papel)
// ─────────────────────────────────────────────────────────────────────────────
enum MemberRole {
  OWNER
  ADMIN
  OPERATOR
}

model Member {
  id             String     @id @default(uuid()) @db.Uuid
  organizationId String     @map("organization_id") @db.Uuid
  userId         String     @map("user_id") @db.Uuid
  role           MemberRole @default(OPERATOR)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("member")
}

// ─────────────────────────────────────────────────────────────────────────────
// User (cliente final, pode ter vários endereços, ser membro de várias organizações)
// ─────────────────────────────────────────────────────────────────────────────

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

model User {
  id          String     @id @default(uuid()) @db.Uuid
  firstName   String     @map("first_name") @db.VarChar(100)
  lastName    String     @map("last_name") @db.VarChar(100)
  email       String     @unique @db.VarChar(255)
  cpf         String     @unique @db.VarChar(14)
  phoneNumber String?    @map("phone_number") @db.VarChar(20)
  status      UserStatus @default(ACTIVE)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  accounts     Account[]
  tokens       Token[]
  members      Member[]
  addresses    Address[]
  otps         Otp[]
  lgpdConsents LgpdConsent[]

  @@index([email])
  @@index([cpf])
  @@index([phoneNumber])
  @@map("user")
}

// ─────────────────────────────────────────────────────────────────────────────
// Endereço do usuário (pode ter vários, um primário)
// ─────────────────────────────────────────────────────────────────────────────
enum AddressType {
  HOME
  WORK
  BILLING
  OTHER
}

model Address {
  id        String      @id @default(uuid()) @db.Uuid
  userId    String      @map("user_id") @db.Uuid
  type      AddressType @default(HOME)
  isPrimary Boolean     @default(false) @map("is_primary")

  street       String  @db.VarChar(255)
  number       String  @db.VarChar(20)
  complement   String? @db.VarChar(100)
  neighborhood String  @db.VarChar(100)
  city         String  @db.VarChar(100)
  state        String  @db.Char(2)
  country      String  @default("BR") @db.Char(2)
  zipCode      String  @map("zip_code") @db.VarChar(10)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("address")
}

// ─────────────────────────────────────────────────────────────────────────────
// AUTH (usuário, conta de login, tokens de sessão, OTP para login por SMS)
// ─────────────────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @db.Uuid
  provider          String  @db.VarChar(50)
  providerAccountId String  @map("provider_account_id")
  passwordHash      String? @map("password_hash")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("account")
}

model Token {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @db.Uuid
  refreshToken String    @map("refresh_token")
  accessToken  String    @map("access_token")
  expiresAt    DateTime
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime? @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("token")
}

model Otp {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String?   @db.Uuid
  phone     String
  codeHash  String
  expiresAt DateTime
  attempts  Int       @default(0)
  usedAt    DateTime?
  users     User[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@index([phone])
  @@map("otp")
}

// ─────────────────────────────────────────────────────────────────────────────
// mercado pago e efi config
// ─────────────────────────────────────────────────────────────────────────────

enum Environment {
  SANDBOX
  PRODUCTION
}

model MercadoPagoConfig {
  id                   Int     @id @default(autoincrement())
  publicKey            String? @map("public_key")
  accessTokenEncrypted String? @map("access_token")
  clientId             String? @map("client_id")
  clientSecret         String? @map("client_secret")
  webhookSecret        String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@map("config_mercadopago")
}

model EfiConfig {
  id           Int         @id @default(autoincrement())
  clientId     String
  clientSecret String
  pixKey       String
  environment  Environment @default(SANDBOX)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@map("efi_config")
}

// ─────────────────────────────────────────────────────────────────────────────
// MIKROTIK — ROTEADOR
// ─────────────────────────────────────────────────────────────────────────────
enum MikrotikStatus {
  ONLINE
  OFFLINE
  ERROR
}

model Mikrotik {
  id             String         @id @default(uuid()) @db.Uuid
  organizationId String         @db.Uuid
  name           String
  host           String
  port           Int            @default(8728)
  macAddress     String         @map("mac_address") @db.VarChar(20)
  ipAddress      String         @map("ip_address") @db.VarChar(15)
  username       String
  passwordHash   String
  status         MikrotikStatus @default(OFFLINE)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  organization Organization  @relation(fields: [organizationId], references: [id])
  vouchers     Voucher[]
  hotspotUsers HotspotUser[]

  @@index([organizationId])
  @@index([host])
  @@map("mikrotik")
}

// ─────────────────────────────────────────────────────────────────────────────
// PLANO DE HOTSPOT
// ─────────────────────────────────────────────────────────────────────────────
enum HotspotPlanType {
  TIME
  DATA
  UNLIMITED
}

model HotspotPlan {
  id             String          @id @default(uuid()) @db.Uuid
  organizationId String          @db.Uuid
  name           String
  type           HotspotPlanType @default(TIME)

  durationSecs Int?
  dataLimitMb  Int?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  vouchers     Voucher[]

  @@index([organizationId])
  @@map("hotspot_plan")
}

// ─────────────────────────────────────────────────────────────────────────────
// USUÁRIO DE HOTSPOT (cliente final da academia/local)
// ─────────────────────────────────────────────────────────────────────────────
enum HotspotUserStatus {
  ACTIVE
  EXPIRED
  BLOCKED
  PENDING
}

model HotspotUser {
  id             String            @id @default(uuid()) @db.Uuid
  organizationId String            @db.Uuid
  mikrotikId     String            @db.Uuid
  username       String
  macAddress     String            @map("mac_address") @db.VarChar(20)
  ipAddress      String            @map("ip_address") @db.VarChar(15)
  passwordHash   String
  status         HotspotUserStatus @default(PENDING)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  mikrotik      Mikrotik       @relation(fields: [mikrotikId], references: [id])
  organizations Organization[]

  @@unique([organizationId, username])
  @@index([organizationId, status])
  @@map("hotspot_user")
}

// ─────────────────────────────────────────────────────────────────────────────
// VOUCHER
// ─────────────────────────────────────────────────────────────────────────────

enum VoucherStatus {
  UNUSED
  ACTIVE
  EXPIRED
  REVOKED
}

model Voucher {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  mikrotikId     String        @map("mikrotik_id") @db.Uuid
  planId         String        @map("plan_id") @db.Uuid
  code           String        @unique @db.VarChar(20) // ex: "XKQP-8821"
  status         VoucherStatus @default(UNUSED)
  usedAt         DateTime?     @map("used_at")
  expiresAt      DateTime?     @map("expires_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime?     @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  mikrotik     Mikrotik     @relation(fields: [mikrotikId], references: [id], onDelete: Cascade)
  plan         HotspotPlan  @relation(fields: [planId], references: [id])

  @@index([organizationId])
  @@index([code])
  @@index([status])
  @@map("voucher")
}

// ─────────────────────────────────────────────────────────────────────────────
// LGPD Consent (registro de consentimento do cliente para marketing, compartilhamento de dados e analytics, necessário para emissão de voucher)
// ─────────────────────────────────────────────────────────────────────────────

// ─────────────────────────────────────────────────────────────────────────────
// LGPD — Consentimento do usuário por organização (SaaS multi-tenant)
// ─────────────────────────────────────────────────────────────────────────────

enum ConsentStatus {
  ACTIVE // consentimento vigente
  REVOKED // usuário revogou
  WITHDRAWN // consentimento expirou ou foi retirado por inatividade
}

model LgpdConsent {
  id             String @id @default(uuid()) @db.Uuid
  userId         String @map("user_id") @db.Uuid
  organizationId String @map("organization_id") @db.Uuid // ← SaaS: por tenant

  // O que o usuário aceitou
  consentTerms       Boolean @map("consent_terms") // termos de uso (obrigatório)
  consentMarketing   Boolean @map("consent_marketing") // e-mail/SMS marketing
  consentDataSharing Boolean @map("consent_data_sharing") // compartilhar com parceiros
  consentAnalytics   Boolean @map("consent_analytics") // análise de comportamento

  // Rastreabilidade (obrigatório pela LGPD)
  ipAddress      String @map("ip_address") @db.VarChar(45) // suporta IPv6
  macAddress     String @map("mac_address") @db.VarChar(20) // opcional
  userAgent      String @map("user_agent") @db.VarChar(500)
  consentVersion String @map("consent_version") @db.VarChar(10) // ex: "v1.2"

  // Ciclo de vida
  status      ConsentStatus @default(ACTIVE)
  withdrawnAt DateTime?     @map("withdrawn_at") // quando revogou

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId, consentVersion]) // evita duplicata por versão
  @@index([userId])
  @@index([organizationId])
  @@index([status])
  @@map("lgpd_consent")
}
